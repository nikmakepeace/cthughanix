{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cmake",
			"label": "CMake: build",
			"command": "build",
			"targets": [
				"[N/A - Select Kit]"
			],
			"group": "build",
			"problemMatcher": [],
			"detail": "CMake template build task"
		},
		{
    		"label": "Build on Debian Etch",
    		"type": "shell",
    		"command": "~/build-cthugha.sh",
			
    		"group": {
    			"kind": "build",
    			"isDefault": true
      		},
			"problemMatcher": {
        		"owner": "cthugha-gcc-src",
        		"fileLocation": ["relative", "${workspaceFolder}/src"],
        		"pattern": [
       
					{
						"regexp": "^([^:\\s][^:]*):(\\d+):\\s+(warning|error):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"severity": 3,
						"message": 4
					}
				]
			},    	
		}
	]
}